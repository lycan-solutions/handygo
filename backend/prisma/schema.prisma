generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CLIENT
  WORKER
  ADMIN
}

enum BookingStatus {
  PENDING
  ACCEPTED
  EN_ROUTE
  ARRIVED
  IN_PROGRESS
  COMPLETED
  REJECTED
  CANCELLED
  EXPIRED
}

enum CancelledByRole {
  CLIENT
  WORKER
}

enum WorkerStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum BookingUrgency {
  URGENT
  NORMAL
}

enum UrgentWindow {
  WITHIN_1_HOUR
  WITHIN_2_HOURS
  WITHIN_4_HOURS
}

enum TimeSlot {
  MORNING
  AFTERNOON
  EVENING
  NIGHT
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum AttachmentType {
  IMAGE
  VIDEO
  AUDIO
}

enum BidStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum MessageType {
  TEXT
  IMAGE
  VIDEO
  VOICE
  LOCATION
  SYSTEM
}

enum AvailabilityStatus {
  OFFLINE
  ONLINE
  BUSY
}

enum BookingLane {
  STANDARD
  INSPECTION
  BIDDING
}

model User {
  id           String    @id @default(uuid())
  phone        String    @unique
  email        String?   @unique
  passwordHash String?
  role         Role
  isActive     Boolean   @default(true)
  fcmToken     String?
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  clientProfile     ClientProfile?
  workerProfile     WorkerProfile?
  refreshTokens     RefreshToken[]
  notifications     Notification[]
  passwordResetOtps PasswordResetOtp[]

  conversationsAsClient Conversation[] @relation("ClientConversations")
  conversationsAsWorker Conversation[] @relation("WorkerConversations")
  chatMessages          Message[]      @relation("ChatMessages")

  @@map("users")
}

model PasswordResetOtp {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  phone      String
  otpHash    String
  expiresAt  DateTime
  consumedAt DateTime?
  attempts   Int       @default(0)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([phone])
  @@index([userId])
  @@index([expiresAt])
  @@index([consumedAt])
  @@map("password_reset_otps")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

model ClientProfile {
  id               String   @id @default(uuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName        String
  lastName         String
  avatarUrl        String?
  avatarStorageKey String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  bookings  Booking[]
  addresses ClientAddress[]

  @@map("client_profiles")
}

model ClientAddress {
  id              String        @id @default(uuid())
  clientProfileId String
  clientProfile   ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)
  label           String
  addressLine     String
  city            String
  latitude        Float
  longitude       Float
  isDefault       Boolean       @default(false)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([clientProfileId])
  @@map("client_addresses")
}

model WorkerProfile {
  id                 String             @id @default(uuid())
  userId             String             @unique
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName          String
  lastName           String
  avatarUrl          String?
  avatarStorageKey   String?
  bio                String?
  status             WorkerStatus       @default(ACTIVE)
  verificationStatus VerificationStatus @default(PENDING)
  isOnline           Boolean            @default(false)
  profileCompleted   Boolean            @default(false)
  availabilityStatus AvailabilityStatus @default(OFFLINE)
  onlineAt           DateTime?          @db.Timestamptz(3)
  currentlyWorking   Boolean            @default(false)
  currentLat         Float?
  currentLng         Float?
  locationUpdatedAt  DateTime?          @db.Timestamptz(3)
  rating             Float              @default(0)
  totalRatings       Int                @default(0)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  skills            WorkerSkill[]
  documents         WorkerDocument[]
  bookings          Booking[]
  bids              Bid[]
  bookingExclusions BookingWorkerExclusion[]

  @@map("worker_profiles")
}

model WorkerSkill {
  id              String          @id @default(uuid())
  workerProfileId String
  workerProfile   WorkerProfile   @relation(fields: [workerProfileId], references: [id], onDelete: Cascade)
  categoryId      String
  category        ServiceCategory @relation(fields: [categoryId], references: [id])
  yearsExperience Int             @default(0)
  createdAt       DateTime        @default(now())

  @@unique([workerProfileId, categoryId])
  @@index([categoryId])
  @@map("worker_skills")
}

model WorkerDocument {
  id              String        @id @default(uuid())
  workerProfileId String
  workerProfile   WorkerProfile @relation(fields: [workerProfileId], references: [id], onDelete: Cascade)
  type            String
  fileUrl         String
  storageKey      String?
  fileName        String?
  mimeType        String?
  sizeBytes       Int?
  verifiedAt      DateTime?
  createdAt       DateTime      @default(now())

  @@index([workerProfileId])
  @@map("worker_documents")
}

model ServiceCategory {
  id            String   @id @default(uuid())
  name          String   @unique
  description   String?
  iconUrl       String?
  isActive      Boolean  @default(true)
  /// Fixed fee charged for an inspection-lane booking in this category.
  /// Null means inspection is not offered for this category.
  inspectionFee Float?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  bookings         Booking[]
  workerSkills     WorkerSkill[]
  standardServices StandardService[]

  @@map("service_categories")
}

model StandardService {
  id          String          @id @default(uuid())
  categoryId  String
  category    ServiceCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  name        String
  description String?
  price       Float
  iconUrl     String?
  isActive    Boolean         @default(true)
  sortOrder   Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  bookings     Booking[]
  bookingItems BookingStandardServiceItem[]

  @@index([categoryId])
  @@map("standard_services")
}

model Booking {
  id              String          @id @default(uuid())
  clientProfileId String
  clientProfile   ClientProfile   @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)
  workerProfileId String?
  workerProfile   WorkerProfile?  @relation(fields: [workerProfileId], references: [id], onDelete: SetNull)
  categoryId      String
  category        ServiceCategory @relation(fields: [categoryId], references: [id])

  status             BookingStatus    @default(PENDING)
  /// Booking lane: STANDARD (fixed-price catalog), INSPECTION (fixed inspection
  /// fee), or BIDDING (open worker bidding). Existing rows default to BIDDING,
  /// preserving current behavior.
  lane               BookingLane      @default(BIDDING)
  urgency            BookingUrgency   @default(NORMAL)
  timeSlot           TimeSlot?
  urgentWindow       UrgentWindow?
  title              String?
  description        String
  inspection         Boolean          @default(false)
  addressLine        String
  city               String
  latitude           Float
  longitude          Float
  scheduledAt        DateTime?
  acceptedAt         DateTime?
  enRouteAt          DateTime?
  arrivedAt          DateTime?
  startedAt          DateTime?
  completedAt        DateTime?
  cancelledAt        DateTime?
  cancellationReason String?
  /// Who initiated the cancellation. Null for non-cancelled bookings, for
  /// EXPIRED bookings (expiry is not a cancellation), and for historical
  /// cancelled rows predating this field.
  cancelledByRole    CancelledByRole?

  /// 72h auto-expiry window for PENDING bookings across all lanes. Set at
  /// creation and reset on relist; the BullMQ expiry job's delay is derived
  /// from this timestamp.
  expiresAt     DateTime?
  /// When the current live/searching window started (creation, or last relist).
  liveStartedAt DateTime?
  /// Last time the client used "Make Live Again" on an EXPIRED booking.
  relistedAt    DateTime?

  /// STANDARD lane: the catalog item picked at booking time (nullable — the
  /// item may later be deleted; the price/name snapshots below remain intact).
  standardServiceId            String?
  standardService              StandardService? @relation(fields: [standardServiceId], references: [id], onDelete: SetNull)
  /// STANDARD lane snapshot — captured at create time so later admin price
  /// edits never retroactively change an existing booking.
  standardServiceNameSnapshot  String?
  standardServicePriceSnapshot Float?
  /// INSPECTION lane snapshot — the category's inspectionFee at create time.
  inspectionFeeSnapshot        Float?

  estimatedPrice Float?
  finalPrice     Float?
  platformFee    Float?

  paymentStatus PaymentStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  statusHistory        BookingStatusHistory[]
  attachments          BookingAttachment[]
  review               Review?
  bids                 Bid[]
  standardServiceItems BookingStandardServiceItem[]
  workerExclusions     BookingWorkerExclusion[]

  @@index([clientProfileId])
  @@index([workerProfileId])
  @@index([categoryId])
  @@index([status])
  @@index([urgency])
  @@index([scheduledAt])
  @@index([lane])
  @@index([standardServiceId])
  @@index([expiresAt])
  @@map("bookings")
}

/// Individual selected STANDARD-lane services for a booking. Supports
/// multiple sub-services per booking (e.g. AC General Service + AC
/// Dismounting). The legacy singular standardServiceId/snapshot fields on
/// Booking remain for backward compatibility; new STANDARD bookings populate
/// both the legacy fields (first/primary item) and this table.
model BookingStandardServiceItem {
  id                String           @id @default(uuid())
  bookingId         String
  booking           Booking          @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  standardServiceId String?
  standardService   StandardService? @relation(fields: [standardServiceId], references: [id], onDelete: SetNull)
  nameSnapshot      String
  priceSnapshot     Float
  quantity          Int              @default(1)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([bookingId])
  @@index([standardServiceId])
  @@map("booking_standard_service_items")
}

/// Tracks workers who cancelled or were otherwise excluded from a specific
/// booking, so they are never re-offered/re-listed for that same booking
/// (survives relist via "Make Live Again").
model BookingWorkerExclusion {
  id              String        @id @default(uuid())
  bookingId       String
  booking         Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  workerProfileId String
  workerProfile   WorkerProfile @relation(fields: [workerProfileId], references: [id], onDelete: Cascade)
  reason          String?
  createdAt       DateTime      @default(now())

  @@unique([bookingId, workerProfileId])
  @@index([bookingId])
  @@index([workerProfileId])
  @@map("booking_worker_exclusions")
}

model BookingStatusHistory {
  id        String        @id @default(uuid())
  bookingId String
  booking   Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  status    BookingStatus
  note      String?
  createdAt DateTime      @default(now())

  @@index([bookingId])
  @@map("booking_status_history")
}

model BookingAttachment {
  id              String         @id @default(uuid())
  bookingId       String
  booking         Booking        @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  type            AttachmentType
  url             String
  storageKey      String?
  fileName        String?
  mimeType        String?
  sizeBytes       Int?
  durationSeconds Float?
  thumbnailUrl    String?
  createdAt       DateTime       @default(now())

  @@index([bookingId])
  @@map("booking_attachments")
}

model Review {
  id        String   @id @default(uuid())
  bookingId String   @unique
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("reviews")
}

model Conversation {
  id                 String    @id @default(uuid())
  clientUserId       String
  clientUser         User      @relation("ClientConversations", fields: [clientUserId], references: [id], onDelete: Cascade)
  workerUserId       String
  workerUser         User      @relation("WorkerConversations", fields: [workerUserId], references: [id], onDelete: Cascade)
  /// The userId of whoever triggered the conversation creation
  createdByUserId    String
  lastMessageAt      DateTime?
  lastMessagePreview String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  messages Message[]

  @@unique([clientUserId, workerUserId])
  @@index([clientUserId])
  @@index([workerUserId])
  @@map("conversations")
}

model Message {
  id               String       @id @default(uuid())
  conversationId   String
  conversation     Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderUserId     String
  sender           User         @relation("ChatMessages", fields: [senderUserId], references: [id], onDelete: Cascade)
  senderRole       Role
  type             MessageType  @default(TEXT)
  text             String?
  mediaUrl         String?
  storageKey       String?
  thumbnailUrl     String?
  mimeType         String?
  fileName         String?
  sizeBytes        Int?
  durationSeconds  Float?
  latitude         Float?
  longitude        Float?
  /// Optional reference to a booking — for context only, not a hard FK
  bookingId        String?
  replyToMessageId String?
  replyTo          Message?     @relation("MessageReplies", fields: [replyToMessageId], references: [id], onDelete: SetNull)
  replies          Message[]    @relation("MessageReplies")
  editedAt         DateTime?
  deletedAt        DateTime?
  seenAt           DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([conversationId])
  @@index([senderUserId])
  @@map("chat_messages")
}

model Notification {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  body        String
  data        Json?
  isRead      Boolean   @default(false)
  readAt      DateTime?
  eventKey    String?
  entityType  String?
  entityId    String?
  bookingId   String?
  actorUserId String?
  actorRole   String?
  route       String?
  payload     Json?
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([userId, isRead])
  @@map("notifications")
}

model Bid {
  id              String        @id @default(uuid())
  bookingId       String
  booking         Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  workerProfileId String
  workerProfile   WorkerProfile @relation(fields: [workerProfileId], references: [id], onDelete: Cascade)
  amount          Decimal       @db.Decimal(10, 2)
  message         String?
  status          BidStatus     @default(PENDING)
  editCount       Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([bookingId, workerProfileId])
  @@index([bookingId])
  @@index([workerProfileId])
  @@map("bids")
}

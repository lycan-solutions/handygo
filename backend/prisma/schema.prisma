generator client {
  provider        = "prisma-client-js"
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
 
}

enum Role {
  CLIENT
  WORKER
  ADMIN
}

enum BookingStatus {
  PENDING
  ACCEPTED
  EN_ROUTE
  IN_PROGRESS
  COMPLETED
  REJECTED
  CANCELLED
}

enum WorkerStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum BookingUrgency {
  URGENT
  NORMAL
}

enum TimeSlot {
  MORNING
  AFTERNOON
  EVENING
  NIGHT
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum AttachmentType {
  IMAGE
  VIDEO
  AUDIO
}

enum BidStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum MessageType {
  TEXT
  IMAGE
  VIDEO
  VOICE
  LOCATION
  SYSTEM
}

enum AvailabilityStatus {
  OFFLINE
  ONLINE
  BUSY
}

model User {
  id           String    @id @default(uuid())
  phone        String    @unique
  email        String?   @unique
  passwordHash String?
  role         Role
  isActive     Boolean   @default(true)
  fcmToken     String?
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  clientProfile ClientProfile?
  workerProfile WorkerProfile?
  refreshTokens RefreshToken[]
  notifications Notification[]
  passwordResetOtps PasswordResetOtp[]

  conversationsAsClient Conversation[] @relation("ClientConversations")
  conversationsAsWorker Conversation[] @relation("WorkerConversations")
  chatMessages          Message[]      @relation("ChatMessages")

  @@map("users")
}

model PasswordResetOtp {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  phone       String
  otpHash     String
  expiresAt   DateTime
  consumedAt  DateTime?
  attempts    Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([phone])
  @@index([userId])
  @@index([expiresAt])
  @@index([consumedAt])
  @@map("password_reset_otps")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

model ClientProfile {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName       String
  lastName        String
  avatarUrl       String?
  avatarStorageKey String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  bookings  Booking[]
  addresses ClientAddress[]

  @@map("client_profiles")
}

model ClientAddress {
  id              String        @id @default(uuid())
  clientProfileId String
  clientProfile   ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)
  label           String
  addressLine     String
  city            String
  latitude        Float
  longitude       Float
  isDefault       Boolean       @default(false)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([clientProfileId])
  @@map("client_addresses")
}

model WorkerProfile {
  id                 String             @id @default(uuid())
  userId             String             @unique
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName          String
  lastName           String
  avatarUrl          String?
  avatarStorageKey   String?
  bio                String?
  status             WorkerStatus       @default(ACTIVE)
  verificationStatus VerificationStatus @default(PENDING)
  isOnline           Boolean            @default(false)
  availabilityStatus AvailabilityStatus @default(OFFLINE)
  onlineAt           DateTime?          @db.Timestamptz(3)
  currentlyWorking   Boolean            @default(false)
  currentLat         Float?
  currentLng         Float?
  locationUpdatedAt  DateTime?          @db.Timestamptz(3)
  rating             Float              @default(0)
  totalRatings       Int                @default(0)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  skills    WorkerSkill[]
  documents WorkerDocument[]
  bookings  Booking[]
  bids      Bid[]

  @@map("worker_profiles")
}

model WorkerSkill {
  id              String          @id @default(uuid())
  workerProfileId String
  workerProfile   WorkerProfile   @relation(fields: [workerProfileId], references: [id], onDelete: Cascade)
  categoryId      String
  category        ServiceCategory @relation(fields: [categoryId], references: [id])
  yearsExperience Int             @default(0)
  createdAt       DateTime        @default(now())

  @@unique([workerProfileId, categoryId])
  @@index([categoryId])
  @@map("worker_skills")
}

model WorkerDocument {
  id              String        @id @default(uuid())
  workerProfileId String
  workerProfile   WorkerProfile @relation(fields: [workerProfileId], references: [id], onDelete: Cascade)
  type            String
  fileUrl         String
  storageKey      String?
  fileName        String?
  mimeType        String?
  sizeBytes       Int?
  verifiedAt      DateTime?
  createdAt       DateTime      @default(now())

  @@index([workerProfileId])
  @@map("worker_documents")
}

model ServiceCategory {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  iconUrl     String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  bookings     Booking[]
  workerSkills WorkerSkill[]

  @@map("service_categories")
}

model Booking {
  id              String          @id @default(uuid())
  clientProfileId String
  clientProfile   ClientProfile   @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)
  workerProfileId String?
  workerProfile   WorkerProfile?  @relation(fields: [workerProfileId], references: [id], onDelete: SetNull)
  categoryId      String
  category        ServiceCategory @relation(fields: [categoryId], references: [id])

  status             BookingStatus  @default(PENDING)
  urgency            BookingUrgency @default(NORMAL)
  timeSlot           TimeSlot?
  title              String?
  description        String
  addressLine        String
  city               String
  latitude           Float
  longitude          Float
  scheduledAt        DateTime?
  acceptedAt         DateTime?
  startedAt          DateTime?
  completedAt        DateTime?
  cancelledAt        DateTime?
  cancellationReason String?

  estimatedPrice Float?
  finalPrice     Float?
  platformFee    Float?

  paymentStatus PaymentStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  statusHistory BookingStatusHistory[]
  attachments   BookingAttachment[]
  review        Review?
  bids          Bid[]

  @@index([clientProfileId])
  @@index([workerProfileId])
  @@index([categoryId])
  @@index([status])
  @@index([urgency])
  @@index([scheduledAt])
  @@map("bookings")
}

model BookingStatusHistory {
  id        String        @id @default(uuid())
  bookingId String
  booking   Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  status    BookingStatus
  note      String?
  createdAt DateTime      @default(now())

  @@index([bookingId])
  @@map("booking_status_history")
}

model BookingAttachment {
  id              String         @id @default(uuid())
  bookingId       String
  booking         Booking        @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  type            AttachmentType
  url             String
  storageKey      String?
  fileName        String?
  mimeType        String?
  sizeBytes       Int?
  durationSeconds Float?
  thumbnailUrl    String?
  createdAt       DateTime       @default(now())

  @@index([bookingId])
  @@map("booking_attachments")
}

model Review {
  id        String   @id @default(uuid())
  bookingId String   @unique
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("reviews")
}

model Conversation {
  id                 String    @id @default(uuid())
  clientUserId       String
  clientUser         User      @relation("ClientConversations", fields: [clientUserId], references: [id], onDelete: Cascade)
  workerUserId       String
  workerUser         User      @relation("WorkerConversations", fields: [workerUserId], references: [id], onDelete: Cascade)
  /// The userId of whoever triggered the conversation creation
  createdByUserId    String
  lastMessageAt      DateTime?
  lastMessagePreview String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  messages Message[]

  @@unique([clientUserId, workerUserId])
  @@index([clientUserId])
  @@index([workerUserId])
  @@map("conversations")
}

model Message {
  id               String       @id @default(uuid())
  conversationId   String
  conversation     Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderUserId     String
  sender           User         @relation("ChatMessages", fields: [senderUserId], references: [id], onDelete: Cascade)
  senderRole       Role
  type             MessageType  @default(TEXT)
  text             String?
  mediaUrl         String?
  storageKey       String?
  thumbnailUrl     String?
  mimeType         String?
  fileName         String?
  sizeBytes        Int?
  durationSeconds  Float?
  latitude         Float?
  longitude        Float?
  /// Optional reference to a booking — for context only, not a hard FK
  bookingId        String?
  replyToMessageId String?
  replyTo          Message?     @relation("MessageReplies", fields: [replyToMessageId], references: [id], onDelete: SetNull)
  replies          Message[]    @relation("MessageReplies")
  editedAt         DateTime?
  deletedAt        DateTime?
  seenAt           DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([conversationId])
  @@index([senderUserId])
  @@map("chat_messages")
}

model Notification {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  body        String
  data        Json?
  isRead      Boolean   @default(false)
  readAt      DateTime?
  eventKey    String?
  entityType  String?
  entityId    String?
  bookingId   String?
  actorUserId String?
  actorRole   String?
  route       String?
  payload     Json?
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([userId, isRead])
  @@map("notifications")
}

model Bid {
  id              String        @id @default(uuid())
  bookingId       String
  booking         Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  workerProfileId String
  workerProfile   WorkerProfile @relation(fields: [workerProfileId], references: [id], onDelete: Cascade)
  amount          Decimal       @db.Decimal(10, 2)
  message         String?
  status          BidStatus     @default(PENDING)
  editCount       Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([bookingId, workerProfileId])
  @@index([bookingId])
  @@index([workerProfileId])
  @@map("bids")
}
